// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Comercio {
  id                  String    @id @default(uuid())
  nombreFantasia      String
  nombreResponsable   String
  apellidoResponsable String
  celular             String?
  email               String    @unique
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relaciones
  usuarios            Usuario[]
  productos           Producto[]
  movimientosStock    MovimientoStock[]
  ventas              Venta[]
  comprobantes        Comprobante[]
  ventaDetalles       VentaDetalle[]
}

model Usuario {
  id               String    @id @default(uuid())
  comercioId       String
  comercio         Comercio  @relation(fields: [comercioId], references: [id])
  email            String    @unique 
  passwordHash     String
  nombre           String?
  rol              Role      @default(CAJERO)
  activo           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  ventasRealizadas      Venta[]
  movimientosRealizados MovimientoStock[]

  @@index([comercioId])
}

enum Role {
  ADMIN
  CAJERO
}

model Producto {
  id               String    @id @default(uuid())
  comercioId       String
  comercio         Comercio  @relation(fields: [comercioId], references: [id])
  codigoInterno    String
  codigoBarras     String?
  nombre           String
  descripcion      String?
  precioCosto      Decimal   @db.Decimal(10, 2)
  precioVenta      Decimal   @db.Decimal(10, 2)
  stockActual      Int       @default(0)
  activo           Boolean   @default(true) 
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  movimientos      MovimientoStock[]
  ventasDetalle    VentaDetalle[]

  @@unique([comercioId, codigoInterno])
  @@index([comercioId])
}

model MovimientoStock {
  id               String    @id @default(uuid())
  comercioId       String
  comercio         Comercio  @relation(fields: [comercioId], references: [id])
  productoId       String
  producto         Producto  @relation(fields: [productoId], references: [id])
  usuarioId        String?
  usuario          Usuario?  @relation(fields: [usuarioId], references: [id])
  tipo             TipoMovimientoStock
  cantidad         Int       
  observaciones    String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([comercioId, productoId])
  @@index([comercioId])
}

enum TipoMovimientoStock {
  INGRESO
  VENTA
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
}

model Venta {
  id               String    @id @default(uuid())
  comercioId       String
  comercio         Comercio  @relation(fields: [comercioId], references: [id])
  usuarioId        String
  usuario          Usuario   @relation(fields: [usuarioId], references: [id])
  total            Decimal   @db.Decimal(12, 2)
  estado           EstadoVenta @default(COMPLETADA)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  detalles         VentaDetalle[]
  comprobante      Comprobante?

  @@index([comercioId])
  @@index([comercioId, createdAt])
}

enum EstadoVenta {
  COMPLETADA
  ANULADA
}

model VentaDetalle {
  id               String    @id @default(uuid())
  comercioId       String
  comercio         Comercio  @relation(fields: [comercioId], references: [id])
  ventaId          String
  venta            Venta     @relation(fields: [ventaId], references: [id])
  productoId       String
  producto         Producto  @relation(fields: [productoId], references: [id])
  cantidad         Int
  precioUnitario   Decimal   @db.Decimal(10, 2) 
  precioCosto      Decimal   @db.Decimal(10, 2) 
  subtotal         Decimal   @db.Decimal(12, 2)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([comercioId, ventaId])
}

model Comprobante {
  id                String    @id @default(uuid())
  comercioId        String
  comercio          Comercio  @relation(fields: [comercioId], references: [id])
  ventaId           String    @unique
  venta             Venta     @relation(fields: [ventaId], references: [id])
  numeroComprobante Int       
  snapshotJSON      Json      
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([comercioId, numeroComprobante])
  @@index([comercioId])
}
